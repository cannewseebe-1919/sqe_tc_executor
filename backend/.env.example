# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/test_executor
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- ADB ---
ADB_PATH=adb
ADB_POLL_INTERVAL=5

# --- Runner App ---
RUNNER_APP_PORT=8080
RUNNER_APP_APK_PATH=runner-app/app/build/outputs/apk/debug/app-debug.apk

# --- Scrcpy ---
SCRCPY_PATH=scrcpy

# --- SAML 2.0 SSO ---
SAML_SETTINGS_PATH=app/core/saml/settings.json

# --- JWT (service-to-service) ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Execution ---
DEFAULT_STEP_TIMEOUT=30
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# --- Crash Detection ---
LOGCAT_POLL_INTERVAL=0.5

# --- App ---
APP_NAME=Test Executor
DEBUG=false
HOST=0.0.0.0
PORT=8000
