# ================================================================
# sqe_tc_executor 백엔드 환경변수
# 이 파일을 .env 로 복사한 뒤 ★ 표시된 항목을 반드시 수정하세요.
#   cp .env.example .env
# ================================================================

# ── 앱 기본 설정 ─────────────────────────────────────────────────
APP_NAME=Test Executor
DEBUG=false
HOST=0.0.0.0
PORT=8000
# DEV_MODE=true 로 설정하면 SAML 인증을 우회합니다 (개발/테스트용)
DEV_MODE=false

# ── 데이터베이스 (PostgreSQL) ─────────────────────────────────────
# Docker Compose 사용 시: @db:5432  /  직접 설치 시: @localhost:5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/test_executor  # ★ 비밀번호 변경
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── ADB 설정 ──────────────────────────────────────────────────────
ADB_PATH=adb
ADB_POLL_INTERVAL=5

# ── Runner App ────────────────────────────────────────────────────
RUNNER_APP_PORT=8080
RUNNER_APP_APK_PATH=runner-app/app/build/outputs/apk/debug/app-debug.apk

# ── scrcpy (화면 스트리밍, 선택) ─────────────────────────────────
SCRCPY_PATH=scrcpy

# ── 실행 설정 ─────────────────────────────────────────────────────
DEFAULT_STEP_TIMEOUT=30
SCREENSHOT_DIR=screenshots
LOG_DIR=logs
LOGCAT_POLL_INTERVAL=0.5

# ── JWT ───────────────────────────────────────────────────────────
# ★ tc_bot의 JWT_SECRET 과 반드시 동일한 값으로 설정하세요
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── SAML 2.0 SSO ─────────────────────────────────────────────────
# ★ 사내 IdP 정보로 변경하세요 (DEV_MODE=true 이면 불필요)
SAML_SETTINGS_PATH=app/core/saml

# ── CORS ──────────────────────────────────────────────────────────
# ★ tc_bot 프론트엔드 주소를 포함하세요
CORS_ORIGINS=["http://tc-bot-server-ip:3000","http://executor-server-ip:3001"]
